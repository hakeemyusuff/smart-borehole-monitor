# DATABASE (used by both the app and the local docker-compose Postgres)
DB_NAME=
DB_USER=
DB_PASSWORD=
DATABASE_URL=postgresql+asyncpg://<user>:<password>@localhost:5432/<db_name>

# APP
SECRET_KEY=            # long random string, e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
DEBUG=false            # true enables SQL echo and debug-level logs

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Background scheduler
# Set to false on all but ONE app process when running multiple workers,
# otherwise every worker will fetch weather on the same interval.
ENABLE_SCHEDULER=true
